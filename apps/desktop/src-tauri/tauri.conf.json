{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zelari Desktop",
  "version": "0.1.0",
  "identifier": "com.nthem.zelari-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zelari Desktop",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Zelari Code desktop shell",
    "longDescription": "Installable desktop shell for Zelari Code — multi-agent coding with optional computer-use later. CLI remains available via npm.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
