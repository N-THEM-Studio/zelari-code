{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zelari Desktop",
  "version": "1.22.0",
  "identifier": "com.nthem.zelari-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zelari Desktop",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "shortDescription": "Zelari Code desktop shell",
    "longDescription": "Installable desktop shell for Zelari Code — multi-agent coding with optional computer-use later. CLI remains available via npm.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/nsis-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp",
        "installMode": "currentUser",
        "languages": [
          "English",
          "Italian"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCM0VFMTg0RTlBQjc3QTUKUldTbGQ2dnBoT0UrSytpZ2hpTTYzQ2hBMFpQTVVxY2hBck15Zk9yUGVsUDYxTmJNMVRmVUJzdkIK",
      "endpoints": [
        "https://github.com/N-THEM-Studio/zelari-code/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
